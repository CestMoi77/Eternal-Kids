@page "/Reserveren"
@model EternalKids.Web.Pages.Reserveren.IndexModel
@{ ViewData["Title"] = "Reserveren"; }

<div class="text-center mb-4">
    <span class="ek-chip">Reserveren</span>
    <h1 class="display-5 mt-2">Offerte in 3 stappen</h1>
    <p class="ek-muted">Een heldere flow met dynamische velden op basis van het gekozen eventtype.</p>
</div>

<form method="post" class="ek-card p-4 bg-white">
    <div id="step1" class="ek-step active">
        <h2 class="h4 mb-3">Stap 1 • Eventdetails</h2>
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Eventtype</label>
                <select asp-for="Input.EventType" class="form-select ek-field" id="eventType">
                    <option>Kinderfeest</option><option>Babyshower</option><option>Bruiloft</option><option>Bedrijf</option>
                </select>
            </div>
            <div class="col-md-6"><label class="form-label">Aantal gasten</label><input asp-for="Input.GuestCount" class="form-control ek-field" type="number" min="1" /></div>
            <div class="col-md-6"><label class="form-label">Datum</label><input asp-for="Input.EventDate" class="form-control ek-field" type="date" /></div>
            <div class="col-md-6" id="childrenAgeWrap"><label class="form-label">Leeftijd kinderen</label><input asp-for="Input.ChildrenAge" class="form-control ek-field" /></div>
            <div class="col-md-6 d-none" id="companyWrap"><label class="form-label">Bedrijfsnaam</label><input asp-for="Input.CompanyName" class="form-control ek-field" /></div>
        </div>
        <div class="text-end mt-3"><button type="button" class="btn ek-btn-book" data-step-next="step2">Volgende</button></div>
    </div>

    <div id="step2" class="ek-step">
        <h2 class="h4 mb-3">Stap 2 • Pakket en voorkeuren</h2>
        <div class="row g-3">
            <div class="col-md-6"><label class="form-label">Pakket</label><select asp-for="Input.PackageType" class="form-select ek-field"><option>Basic</option><option>Elegant</option><option>Prestige</option><option>Deluxe</option></select></div>
            <div class="col-md-6"><label class="form-label">Budget (€)</label><input asp-for="Input.Budget" type="number" min="0" class="form-control ek-field" /></div>
            <div class="col-12"><label class="form-label">Opmerkingen</label><textarea asp-for="Input.Notes" rows="4" class="form-control ek-field"></textarea></div>
        </div>
        <div class="mt-3 d-flex justify-content-between"><button type="button" class="btn btn-light border" data-step-prev="step1">Terug</button><button type="button" class="btn ek-btn-book" data-step-next="step3">Volgende</button></div>
    </div>

    <div id="step3" class="ek-step">
        <h2 class="h4 mb-3">Stap 3 • Contact & betaling</h2>
        <div class="row g-3">
            <div class="col-md-6"><input asp-for="Input.Name" class="form-control ek-field" placeholder="Naam" /></div>
            <div class="col-md-6"><input asp-for="Input.Email" class="form-control ek-field" placeholder="E-mail" /></div>
            <div class="col-md-6"><input asp-for="Input.Phone" class="form-control ek-field" placeholder="Telefoon" /></div>
            <div class="col-md-6"><select asp-for="Input.PaymentMode" class="form-select ek-field"><option value="Deposit50">50% aanbetaling</option><option value="Full">100% betaling</option></select></div>
        </div>
        <div class="mt-3 d-flex justify-content-between"><button type="button" class="btn btn-light border" data-step-prev="step2">Terug</button><button type="submit" class="btn ek-btn-book">Offerte aanvragen</button></div>
    </div>

    @if (Model.Submitted)
    {
        <div class="alert alert-success mt-3 mb-0">Bedankt! Uw aanvraag is ontvangen. Wij reageren binnen 24 uur.</div>
    }
</form>

@section Scripts {
<script>
(function(){
    const eventType = document.getElementById('eventType');
    const childrenAgeWrap = document.getElementById('childrenAgeWrap');
    const companyWrap = document.getElementById('companyWrap');

    function toggleDynamic(){
        const v = (eventType.value || '').toLowerCase();
        childrenAgeWrap.classList.toggle('d-none', !(v.includes('kinderfeest') || v.includes('babyshower')));
        companyWrap.classList.toggle('d-none', !v.includes('bedrijf'));
    }

    eventType.addEventListener('change', toggleDynamic);
    toggleDynamic();
})();
</script>
}
