@model EternalKids.Web.Pages.Shared.CartSummaryViewModel

<a class="nav-link d-inline-flex align-items-center gap-2" asp-page="/Checkout/Index" aria-label="Open winkelwagen">
    <span class="ek-icon-dot" style="width:32px;height:32px;">🛒</span>
    <span class="small fw-semibold">
        @Model.ItemCount items
        <span class="ek-muted">• € @Model.Subtotal.ToString("N2")</span>
    </span>
</a>
