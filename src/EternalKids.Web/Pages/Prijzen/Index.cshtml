@page "/Prijzen"
@model EternalKids.Web.Pages.Prijzen.IndexModel
@{
    ViewData["Title"] = "Prijzen";
}

<section class="ek-pricing-hero mb-4 p-4 p-md-5 rounded-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-4 align-items-lg-end">
        <div>
            <p class="text-uppercase small mb-2 ek-eyebrow">Eternal Kids Pricing Studio</p>
            <h1 class="display-6 fw-bold mb-2">Transparante pakketten voor elk droomfeest</h1>
            <p class="mb-0 text-muted">Kies eventtype en aantal gasten. Wij tonen live prijzen per pakket op basis van Prijzenbeheer.</p>
        </div>
    </div>
</section>

<form method="post" class="ek-pricing-form card border-0 shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
        <div class="col-md-5">
            <label asp-for="Input.EventType" class="form-label fw-semibold">Eventtype</label>
            <select asp-for="Input.EventType" class="form-select" asp-items="Model.EventTypeOptions"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.GuestCount" class="form-label fw-semibold">Aantal gasten</label>
            <input asp-for="Input.GuestCount" type="number" min="1" class="form-control" />
            <span asp-validation-for="Input.GuestCount" class="text-danger small"></span>
        </div>
        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-dark">Bereken prijzen</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="row g-4">
    @foreach (var card in Model.PackageCards)
    {
        <div class="col-sm-6 col-xl-3">
            <article class="card h-100 border-0 shadow-sm ek-price-card">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h2 class="h5 mb-0">@card.PackageType</h2>
                        @if (card.IsFeatured)
                        {
                            <span class="badge rounded-pill text-bg-dark">Populair</span>
                        }
                    </div>
                    <p class="text-muted small mb-3">@Model.Input.EventType • @Model.Input.GuestCount gasten</p>
                    <p class="display-6 fw-bold mb-3">€ @card.Price.ToString("N2")</p>
                    <ul class="small text-muted ps-3 mb-4">
                        @foreach (var item in card.Highlights)
                        {
                            <li>@item</li>
                        }
                    </ul>
                    <button type="button" class="btn btn-outline-dark mt-auto">Kies @card.PackageType</button>
                </div>
            </article>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .ek-pricing-hero {
        background: radial-gradient(circle at top right, #f5d0fe, #eef2ff 55%, #ffffff);
    }

    .ek-eyebrow {
        letter-spacing: .08em;
        color: #7e22ce;
        font-weight: 700;
    }

    .ek-price-card {
        border-radius: 1rem;
        transition: transform .2s ease, box-shadow .2s ease;
    }

    .ek-price-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 1rem 2rem rgba(0,0,0,.08) !important;
    }
</style>
