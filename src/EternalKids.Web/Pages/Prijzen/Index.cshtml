@page "/Prijzen"
@model EternalKids.Web.Pages.Prijzen.IndexModel
@{ ViewData["Title"] = "Prijzen"; }

<div class="text-center mb-4">
    <span class="ek-chip">Prijzen</span>
    <h1 class="display-5 mt-2">Realtime prijsindicatie</h1>
    <p class="ek-muted">Selecteer eventtype en aantal gasten voor actuele pakketprijzen.</p>
</div>

<form method="post" class="ek-card p-4 mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label asp-for="Input.EventType" class="form-label">Eventtype</label>
            <select asp-for="Input.EventType" asp-items="Model.EventTypeOptions" class="form-select ek-field"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.GuestCount" class="form-label">Aantal gasten</label>
            <input asp-for="Input.GuestCount" type="number" min="1" class="form-control ek-field" />
            <span asp-validation-for="Input.GuestCount" class="text-danger small"></span>
        </div>
        <div class="col-md-3 d-grid">
            <button class="btn ek-btn-book" type="submit">Bereken</button>
        </div>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<div class="row g-4">
    @foreach (var card in Model.PackageCards)
    {
        <div class="col-sm-6 col-xl-3">
            <div class="ek-card ek-card-hover h-100 p-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h4 mb-0">@card.PackageType</h2>
                    @if (card.IsFeatured)
                    {
                        <span class="badge rounded-pill text-bg-dark">Populair</span>
                    }
                </div>
                <p class="small ek-muted mb-2">@Model.Input.EventType • @Model.Input.GuestCount gasten</p>
                <p class="display-6 mb-3">€ @card.Price.ToString("N2")</p>
                <ul class="small ek-muted ps-3 mb-0">
                    @foreach (var item in card.Highlights)
                    {
                        <li>@item</li>
                    }
                </ul>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
