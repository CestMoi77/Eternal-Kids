@page "/Checkout"
@model EternalKids.Web.Pages.Checkout.IndexModel
@{ ViewData["Title"] = "Checkout"; }

<div class="row g-4">
    <div class="col-lg-7">
        <section class="ek-card p-4 bg-white h-100">
            <span class="ek-chip">Checkout</span>
            <h1 class="display-6 mt-2">Rond uw reservering af</h1>
            <p class="ek-muted">Duidelijke invoerflow met keuze voor volledige betaling of 50% aanbetaling.</p>

            <form method="post" class="row g-3">
                <div class="col-md-6"><label class="form-label">Naam</label><input asp-for="Input.CustomerName" class="form-control ek-field" /><span asp-validation-for="Input.CustomerName" class="text-danger small"></span></div>
                <div class="col-md-6"><label class="form-label">E-mail</label><input asp-for="Input.CustomerEmail" class="form-control ek-field" /><span asp-validation-for="Input.CustomerEmail" class="text-danger small"></span></div>
                <div class="col-md-6"><label class="form-label">Eventdatum</label><input asp-for="Input.EventDate" type="date" class="form-control ek-field" /></div>
                <div class="col-md-6"><label class="form-label">Eventtype</label><input asp-for="Input.EventType" class="form-control ek-field" /></div>
                <div class="col-md-6"><label class="form-label">Aantal gasten</label><input asp-for="Input.GuestCount" type="number" min="1" class="form-control ek-field" /></div>
                <div class="col-md-6">
                    <label class="form-label d-block">Betaalkeuze</label>
                    <div class="form-check"><input class="form-check-input" type="radio" asp-for="Input.PaymentMode" value="Full" id="payFull" /><label class="form-check-label" for="payFull">100% volledig</label></div>
                    <div class="form-check"><input class="form-check-input" type="radio" asp-for="Input.PaymentMode" value="Deposit50" id="payDeposit" /><label class="form-check-label" for="payDeposit">50% aanbetaling</label></div>
                </div>
                <div class="col-12 d-grid"><button class="btn ek-btn-book btn-lg" type="submit">Bestellen</button></div>
            </form>
        </section>
    </div>

    <div class="col-lg-5">
        <aside class="ek-card p-4 bg-white h-100">
            <h2 class="h5 mb-3">Orderoverzicht</h2>
            <dl class="row mb-0">
                <dt class="col-6">Subtotaal</dt><dd class="col-6 text-end">€ @Model.Subtotal.ToString("N2")</dd>
                <dt class="col-6">Korting</dt><dd class="col-6 text-end">€ @Model.DiscountTotal.ToString("N2")</dd>
                <dt class="col-6">Totaal</dt><dd class="col-6 text-end fw-bold">€ @Model.GrandTotal.ToString("N2")</dd>
                <dt class="col-6">Aanbetaling</dt><dd class="col-6 text-end">€ @Model.DepositAmount.ToString("N2")</dd>
            </dl>
            @if (!string.IsNullOrWhiteSpace(Model.ResultMessage))
            {
                <div class="alert alert-success mt-3 mb-0">@Model.ResultMessage</div>
            }
        </aside>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
