@page "/Diensten"
@model EternalKids.Web.Pages.Diensten.IndexModel
@{ ViewData["Title"] = "Diensten"; }

<div class="text-center mb-4">
    <span class="ek-chip">Onze Diensten</span>
    <h1 class="display-5 mt-2">Wat Wij Bieden</h1>
</div>

<div class="row g-4">
    @foreach (var service in Model.Services)
    {
        <div class="col-md-4">
            <article class="ek-card p-4 bg-white h-100">
                <h2 class="h4">@service.Title</h2>
                <p class="text-secondary">@service.Description</p>
                <button class="btn btn-sm btn-outline-dark" data-bs-toggle="modal" data-bs-target="#m-@service.Key">Bekijk details</button>
            </article>
        </div>

        <div class="modal fade" id="m-@service.Key" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 ek-card">
                    <div class="modal-header">
                        <h5 class="modal-title">@service.Title</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body"><p class="mb-0">@service.LongDescription</p></div>
                </div>
            </div>
        </div>
    }
</div>
