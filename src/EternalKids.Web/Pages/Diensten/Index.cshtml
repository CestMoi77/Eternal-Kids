@page "/Diensten"
@model EternalKids.Web.Pages.Diensten.IndexModel
@{ ViewData["Title"] = "Diensten"; }

<div class="text-center mb-4">
    <span class="ek-chip">Onze diensten</span>
    <h1 class="display-5 mt-2">Alles voor uw event</h1>
    <p class="ek-muted">Selecteer een dienst en bekijk details in de modal.</p>
</div>

<div class="row g-4">
    @foreach (var service in Model.Services)
    {
        <div class="col-md-6 col-xl-4">
            <article class="ek-card ek-card-hover p-4 h-100">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h2 class="h4 mb-0">@service.Title</h2>
                    <span class="ek-icon-dot">★</span>
                </div>
                <p class="ek-muted">@service.Description</p>
                <button class="btn btn-outline-dark btn-sm mt-auto" data-bs-toggle="modal" data-bs-target="#m-@service.Key">Bekijk details</button>
            </article>
        </div>

        <div class="modal fade" id="m-@service.Key" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 ek-card">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title">@service.Title</h5>
                        <button class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body pt-2">
                        <p class="mb-0 ek-muted">@service.LongDescription</p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
