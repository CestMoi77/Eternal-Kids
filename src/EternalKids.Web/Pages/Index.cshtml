@page
@model EternalKids.Web.Pages.IndexModel
@{ ViewData["Title"] = "Home"; }

<section class="ek-hero">
    <div class="row g-4 align-items-center">
        <div class="col-lg-6">
            <span class="ek-chip">Event Planning & Luxury Styling</span>
            <h1 class="display-4 mt-3">Maak elk moment magisch</h1>
            <p class="lead ek-muted">Eternal Kids transformeert ideeën naar premium event-ervaringen: van creatieve concepten tot vlekkeloze uitvoering.</p>
            <div class="d-flex flex-wrap gap-2 mt-4">
                <a asp-page="/Reserveren/Index" class="btn ek-btn-book">Boek direct</a>
                <a asp-page="/Pakketten/Index" class="btn btn-light border">Bekijk pakketten</a>
            </div>
            <div class="d-flex gap-4 mt-4 small ek-muted">
                <div><strong class="text-dark">11+</strong><br/>jaar ervaring</div>
                <div><strong class="text-dark">850+</strong><br/>events verzorgd</div>
                <div><strong class="text-dark">98%</strong><br/>tevreden klanten</div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="ek-card ek-card-hover p-3">
                <img src="https://images.unsplash.com/photo-1464349153735-7db50ed83c84?q=80&w=1400&auto=format&fit=crop" class="img-fluid rounded-3" alt="Luxury event" />
            </div>
        </div>
    </div>
</section>

<section class="py-4">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <span class="ek-chip">Diensten</span>
            <h2 class="mt-2 mb-0">Wat wij aanbieden</h2>
        </div>
        <a asp-page="/Diensten/Index" class="small fw-semibold">Alles bekijken →</a>
    </div>
    <div class="row g-3">
        @foreach (var service in Model.Services)
        {
            <div class="col-md-4">
                <article class="ek-card ek-card-hover h-100 p-4">
                    <div class="ek-icon-dot mb-3">✦</div>
                    <h3 class="h4 mb-2">@service.Title</h3>
                    <p class="ek-muted mb-0">@service.Description</p>
                </article>
            </div>
        }
    </div>
</section>

<section class="py-4">
    <span class="ek-chip">Reviews</span>
    <h2 class="mt-2 mb-3">Wat klanten zeggen</h2>
    <div class="row g-3">
        @foreach (var review in Model.Reviews)
        {
            <div class="col-md-4">
                <div class="ek-card p-4 h-100">
                    <p class="mb-3">“@review.Text”</p>
                    <strong>@review.Author</strong>
                </div>
            </div>
        }
    </div>
</section>
