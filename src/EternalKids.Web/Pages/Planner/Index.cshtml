@page "/Planner"
@model EternalKids.Web.Pages.Planner.IndexModel
@{ ViewData["Title"] = "AI Planner"; }

<div class="text-center mb-4">
    <span class="ek-chip">AI Planner</span>
    <h1 class="display-5 mt-2">Plan uw feest in 3 slimme stappen</h1>
    <p class="ek-muted">Conversational wizard met realtime prijsadvies en directe checkout.</p>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="ek-card p-4 h-100">
            <h2 class="h5 mb-3">Planner instellingen</h2>
            <div class="mb-3"><label class="form-label">Eventtype</label><select id="eventType" class="form-select ek-field"><option>Kinderfeest</option><option>Verjaardag</option><option>Babyshower</option><option>Bruiloft</option><option>Bedrijf</option></select></div>
            <div class="mb-3"><label class="form-label">Pakket</label><select id="packageType" class="form-select ek-field"><option>Basic</option><option>Elegant</option><option>Prestige</option><option>Deluxe</option></select></div>
            <div class="mb-3"><label class="form-label">Aantal gasten</label><input id="guestCount" class="form-control ek-field" type="number" value="30" min="1" /></div>
            <button id="bookNowFromAi" class="btn ek-btn-gold w-100 d-none" type="button">Direct boeken</button>
        </div>
    </div>
    <div class="col-lg-8">
        <section class="ek-chat-shell overflow-hidden">
            <div class="p-3 text-white" style="background:linear-gradient(90deg,#1f2937,#374151)">
                <strong>Eternal Kids AI Assistant</strong>
                <div class="small opacity-75">Online • Realtime pricing gekoppeld</div>
            </div>
            <div class="p-3" id="chatMessages" style="height:380px; overflow:auto; background:#fbfcfe;">
                <div class="ek-bubble-assistant">Welkom! Beschrijf uw event en ik stel direct een passend plan voor.</div>
            </div>
            <div class="p-3 border-top">
                <form id="chatForm" class="d-flex gap-2">
                    <input id="chatInput" class="form-control ek-field" placeholder="Typ je bericht..." />
                    <button class="btn ek-btn-book" type="submit">Verstuur</button>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
const sessionId = "@Model.SessionId";
const chatMessages = document.getElementById("chatMessages");
const chatForm = document.getElementById("chatForm");
const bookNowBtn = document.getElementById("bookNowFromAi");
const connection = new signalR.HubConnectionBuilder().withUrl("/hubs/chat").withAutomaticReconnect().build();

function addBubble(text, user){
    const el = document.createElement("div");
    el.className = user ? "ek-bubble-user" : "ek-bubble-assistant";
    el.textContent = text;
    chatMessages.appendChild(el);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

connection.on("ReceiveAssistantMessage", payload => {
    addBubble(payload.message, false);
    const actions = payload.uiActions || [];
    const hasCheckout = actions.some(x => (x.type || '').toLowerCase() === 'checkout');
    bookNowBtn.classList.toggle('d-none', !hasCheckout);
});

bookNowBtn.addEventListener('click', () => {
    const eventType = document.getElementById("eventType").value;
    const guestCount = document.getElementById("guestCount").value;
    const packageType = document.getElementById("packageType").value;
    window.location.href = `/Checkout?eventType=${encodeURIComponent(eventType)}&guestCount=${encodeURIComponent(guestCount)}&packageType=${encodeURIComponent(packageType)}`;
});

chatForm.addEventListener("submit", async (e) => {
    e.preventDefault();
    const message = document.getElementById("chatInput").value;
    if (!message.trim()) return;
    addBubble(message, true);
    document.getElementById("chatInput").value = "";
    await connection.invoke("SendMessage", {
        sessionId,
        message,
        eventType: document.getElementById("eventType").value,
        packageType: document.getElementById("packageType").value,
        guestCount: parseInt(document.getElementById("guestCount").value || "0", 10),
        quantity: 1
    });
});

(async function(){ await connection.start(); await connection.invoke("JoinSession", sessionId); })();
</script>
}
