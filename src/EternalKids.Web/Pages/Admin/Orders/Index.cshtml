@page "/Admin/Orders"
@model EternalKids.Web.Pages.Admin.Orders.IndexModel
@{ Layout = "/Pages/Admin/_AdminLayout.cshtml"; ViewData["Title"] = "Orders"; }

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label class="form-label">Status filter</label>
        <select class="form-select ek-field" name="status" asp-for="StatusFilter" asp-items="Model.StatusOptions"></select>
    </div>
    <div class="col-md-2 d-grid align-self-end"><button class="btn btn-dark">Filter</button></div>
</form>

<div class="table-responsive ek-table-wrap">
    <table class="table align-middle mb-0">
        <thead>
            <tr><th>Order</th><th>Event</th><th>Status</th><th>Totaal</th><th>Aanbetaling</th><th>Actie</th></tr>
        </thead>
        <tbody>
        @foreach (var order in Model.Orders)
        {
            <tr>
                <td class="fw-semibold">@order.OrderNumber</td>
                <td>@order.EventType (@order.GuestCount)</td>
                <td><span class="badge text-bg-secondary">@order.Status</span></td>
                <td>€ @order.GrandTotal.ToString("N2")</td>
                <td>€ @order.DepositAmount.ToString("N2")</td>
                <td><a class="btn btn-sm btn-outline-dark" asp-page="/Admin/Orders/Details" asp-route-id="@order.Id">Details</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>
