@page "/Admin/Orders/{id:guid}"
@model EternalKids.Web.Pages.Admin.Orders.DetailsModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Order Details";
}

@if (Model.Order is null)
{
    <div class="alert alert-warning">Order niet gevonden.</div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5">@Model.Order.OrderNumber</h2>
            <p class="mb-1"><strong>Status:</strong> @Model.Order.Status</p>
            <p class="mb-1"><strong>Event:</strong> @Model.Order.EventType op @Model.Order.EventDate</p>
            <p class="mb-0"><strong>Totaal:</strong> € @Model.Order.GrandTotal.ToString("N2")</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h3 class="h6">Order items inclusief OptionsJson</h3>
            @foreach (var item in Model.Order.Items)
            {
                <div class="border rounded p-2 mb-2">
                    <div><strong>@item.DescriptionSnapshot</strong> • @item.Quantity x € @item.UnitPrice.ToString("N2")</div>
                    <div class="small text-muted">LineTotal: € @item.LineTotal.ToString("N2")</div>
                    <pre class="bg-light p-2 small mb-0">@item.OptionsJson</pre>
                </div>
            }
        </div>
    </div>
}
