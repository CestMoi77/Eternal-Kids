@page "/Admin/Content"
@model EternalKids.Web.Pages.Admin.Content.IndexModel
@{ Layout = "/Pages/Admin/_AdminLayout.cshtml"; ViewData["Title"] = "Content Management"; }

<div class="ek-card p-3 mb-3">
    <h2 class="h6 mb-3">Blok bewerken of toevoegen</h2>
    <form method="post" asp-page-handler="Save" class="row g-2">
        <div class="col-md-2"><input asp-for="Input.PageKey" class="form-control ek-field" placeholder="PageKey" /></div>
        <div class="col-md-2"><input asp-for="Input.SectionKey" class="form-control ek-field" placeholder="SectionKey" /></div>
        <div class="col-md-3"><input asp-for="Input.Title" class="form-control ek-field" placeholder="Titel" /></div>
        <div class="col-md-3"><input asp-for="Input.Body" class="form-control ek-field" placeholder="Body" /></div>
        <div class="col-md-2 d-grid"><button class="btn btn-dark">Opslaan</button></div>
    </form>
</div>

<div class="table-responsive ek-table-wrap">
    <table class="table table-sm mb-0 align-middle">
        <thead><tr><th>Pagina</th><th>Sectie</th><th>Titel</th><th>Body</th></tr></thead>
        <tbody>
        @foreach (var item in Model.Items)
        {
            <tr><td>@item.PageKey</td><td>@item.SectionKey</td><td>@item.Title</td><td>@item.Body</td></tr>
        }
        </tbody>
    </table>
</div>
