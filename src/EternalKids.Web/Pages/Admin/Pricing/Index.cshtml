@page "/Admin/Pricing"
@model EternalKids.Web.Pages.Admin.Pricing.IndexModel
@{ Layout = "/Pages/Admin/_AdminLayout.cshtml"; ViewData["Title"] = "Prijzenbeheer"; }

<div class="row g-4">
    <div class="col-lg-4">
        <div class="ek-card p-3 h-100">
            <h2 class="h6 mb-3">Nieuwe prijsregel</h2>
            <form method="post" asp-page-handler="Create" class="row g-2">
                <div class="col-12"><input asp-for="CreateInput.EventType" class="form-control ek-field" placeholder="Eventtype" /></div>
                <div class="col-12"><input asp-for="CreateInput.PackageType" class="form-control ek-field" placeholder="Pakket" /></div>
                <div class="col-6"><input asp-for="CreateInput.MinGuests" class="form-control ek-field" placeholder="Min" /></div>
                <div class="col-6"><input asp-for="CreateInput.MaxGuests" class="form-control ek-field" placeholder="Max" /></div>
                <div class="col-12"><input asp-for="CreateInput.Price" class="form-control ek-field" placeholder="Prijs" /></div>
                <div class="col-12 d-grid"><button class="btn btn-dark">Toevoegen</button></div>
            </form>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="table-responsive ek-table-wrap">
            <table class="table mb-0 align-middle">
                <thead><tr><th>Event</th><th>Pakket</th><th>Range</th><th>Prijs</th><th></th></tr></thead>
                <tbody>
                @foreach (var rule in Model.Rules)
                {
                    <tr>
                        <td>@rule.EventType</td>
                        <td>@rule.PackageType</td>
                        <td>@rule.MinGuests - @rule.MaxGuests</td>
                        <td>€ @rule.Price.ToString("N2")</td>
                        <td>
                            <form method="post" asp-page-handler="Delete" class="d-inline">
                                <input type="hidden" name="id" value="@rule.Id" />
                                <button class="btn btn-sm btn-outline-danger">Verwijder</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
