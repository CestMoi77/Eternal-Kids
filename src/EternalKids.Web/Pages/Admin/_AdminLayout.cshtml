<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Eternal Kids Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background:#f3f4f6; }
        .ek-admin-sidebar { background:#111827; min-height:100vh; }
        .ek-admin-brand { color:#fff; font-weight:700; text-decoration:none; }
        .ek-admin-link { color:#d1d5db; text-decoration:none; display:block; padding:.65rem .8rem; border-radius:.5rem; }
        .ek-admin-link:hover, .ek-admin-link.active { background:#374151; color:#fff; }
        .ek-admin-topbar { background:#fff; border-bottom:1px solid #e5e7eb; }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <aside class="col-md-3 col-lg-2 ek-admin-sidebar p-3">
            <a class="ek-admin-brand d-block mb-4" asp-page="/Admin/Orders/Index">Eternal Kids Admin</a>
            <nav class="d-grid gap-1">
                <a class="ek-admin-link" asp-page="/Admin/Orders/Index">Orders</a>
                <a class="ek-admin-link" asp-page="/Admin/Pricing/Index">Prijzenbeheer</a>
                <a class="ek-admin-link" asp-page="/Admin/AiLogs/Index">AI Logs</a>
                <a class="ek-admin-link" asp-page="/Index">Terug naar site</a>
            </nav>
        </aside>
        <main class="col-md-9 col-lg-10 px-0">
            <header class="ek-admin-topbar px-4 py-3">
                <h1 class="h5 mb-0">@ViewData["Title"]</h1>
            </header>
            <section class="p-4">
                @RenderBody()
            </section>
        </main>
    </div>
</div>
@await RenderSectionAsync("Scripts", required:false)
</body>
</html>
