@page "/Admin/AiLogs"
@model EternalKids.Web.Pages.Admin.AiLogs.IndexModel
@{ Layout = "/Pages/Admin/_AdminLayout.cshtml"; ViewData["Title"] = "AI Log Analyse"; }

<div class="table-responsive ek-table-wrap">
    <table class="table table-sm align-middle mb-0">
        <thead>
            <tr><th>Datum</th><th>Model</th><th>PromptHash</th><th>Tokens</th><th>ToolCalls</th><th>Status</th></tr>
        </thead>
        <tbody>
        @foreach (var log in Model.Logs)
        {
            <tr>
                <td>@log.CreatedAtUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                <td>@log.Model</td>
                <td><code class="small">@log.PromptHash</code></td>
                <td>@log.TokensIn / @log.TokensOut</td>
                <td><pre class="bg-light p-2 mb-0 small">@log.ToolCallsJson</pre></td>
                <td>@if (log.Succeeded) { <span class="badge text-bg-success">Success</span> } else { <span class="badge text-bg-danger">Error</span> }</td>
            </tr>
        }
        </tbody>
    </table>
</div>
