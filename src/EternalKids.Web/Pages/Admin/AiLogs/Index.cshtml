@page "/Admin/AiLogs"
@model EternalKids.Web.Pages.Admin.AiLogs.IndexModel
@{
    Layout = "/Pages/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "AI Log Analyse";
}

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle">
                <thead>
                <tr>
                    <th>Datum</th>
                    <th>Model</th>
                    <th>PromptHash</th>
                    <th>Tokens (in/out)</th>
                    <th>ToolCalls</th>
                    <th>Status</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@log.CreatedAtUtc.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</td>
                        <td>@log.Model</td>
                        <td class="small"><code>@log.PromptHash</code></td>
                        <td>@log.TokensIn / @log.TokensOut</td>
                        <td class="small"><pre class="mb-0 bg-light p-2">@log.ToolCallsJson</pre></td>
                        <td>
                            @if (log.Succeeded)
                            {
                                <span class="badge text-bg-success">Success</span>
                            }
                            else
                            {
                                <span class="badge text-bg-danger">Error</span>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
